# =============================================================================
# Twitter/X Growth Automation - Ortam Değişkenleri
# =============================================================================
# Bu dosyayı .env olarak kopyalayın ve kendi API anahtarlarınızı girin.
#
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# TWITTER/X API
# -----------------------------------------------------------------------------
# Twitter Developer Portal'dan alın: https://developer.twitter.com/
# Pro veya Basic tier gerekli (ücretsiz tier ile trend verisi alınamaz)

TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here
TWITTER_BEARER_TOKEN=your_bearer_token_here

# -----------------------------------------------------------------------------
# AI API (En az birini doldurun)
# -----------------------------------------------------------------------------

# OpenAI API (GPT-4)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# Anthropic API (Claude)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your_anthropic_key_here

# -----------------------------------------------------------------------------
# GÖRSEL API'LER (Opsiyonel ama önerilir)
# -----------------------------------------------------------------------------

# Unsplash API (Ücretsiz, 50 istek/saat)
# https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_key_here

# Pexels API (Ücretsiz, 200 istek/saat)
# https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_key_here

# -----------------------------------------------------------------------------
# OPSIYONEL AYARLAR
# -----------------------------------------------------------------------------

# Zaman dilimi (varsayılan: Europe/Istanbul)
# TIMEZONE=Europe/Istanbul

# Günlük maksimum tweet (varsayılan: 5)
# MAX_TWEETS_PER_DAY=5

# Debug modu (varsayılan: False)
# DEBUG=False
