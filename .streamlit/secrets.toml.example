# Streamlit Cloud için bu değerleri "App Settings > Secrets" bölümüne girin
# https://docs.streamlit.io/deploy/streamlit-community-cloud/deploy-your-app/secrets-management

# Twitter API (opsiyonel - ucretsiz scraping kullanilabilir)
TWITTER_API_KEY = "your_api_key"
TWITTER_API_SECRET = "your_api_secret"
TWITTER_ACCESS_TOKEN = "your_access_token"
TWITTER_ACCESS_TOKEN_SECRET = "your_access_token_secret"
TWITTER_BEARER_TOKEN = "your_bearer_token"

# AI API - Gemini UCRETSIZ ve ONERILEN!
# Gemini API key almak icin: https://aistudio.google.com/app/apikey
GEMINI_API_KEY = "your_gemini_api_key"

# Alternatif AI API'ler (opsiyonel)
OPENAI_API_KEY = "sk-your_openai_key"
ANTHROPIC_API_KEY = "sk-ant-your_anthropic_key"

# Görsel API (opsiyonel)
UNSPLASH_ACCESS_KEY = "your_unsplash_key"
PEXELS_API_KEY = "your_pexels_key"
